# GitLab CI/CD Variables
# ─────────────────────────────────────────────────────────────────────────────
# Set these in each repo under:
#   Settings → CI/CD → Variables
#
# Mark PACT_BROKER_PASSWORD as "Masked" so it never appears in job logs.
# Mark all three broker vars as "Protected" if you only want them on
# protected branches (main / tags).
# ─────────────────────────────────────────────────────────────────────────────

# ── PACT Broker connection ────────────────────────────────────────────────────
PACT_BROKER_BASE_URL=https://your-broker.example.com   # or http://localhost:9292 for local
PACT_BROKER_USERNAME=pact
PACT_BROKER_PASSWORD=<your-secret>                     # ← MASK THIS in GitLab UI

# ── Optional: PactFlow (hosted broker) instead of self-hosted ────────────────
# If using PactFlow (https://pactflow.io) replace the three vars above with:
# PACT_BROKER_BASE_URL=https://<your-org>.pactflow.io
# PACT_BROKER_TOKEN=<read-write API token>             # ← MASK THIS
# And update the pipeline --broker-token flag instead of --broker-username/password

# ── Consumer repo only ────────────────────────────────────────────────────────
PROVIDER_BASE_URL=http://provider:80                   # internal Docker network name

# ── Provider repo only ────────────────────────────────────────────────────────
PROVIDER_BASE_URL=http://localhost:8002                # PHP built-in server in CI job
